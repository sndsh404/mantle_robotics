# Mantle Robotics — environment variables
#
# No environment variables are currently required to run this project.
# This file is kept as a template: when a variable is added, document it
# here with a placeholder value, then copy this file to .env.local and
# fill in the real value. Never commit .env* files (already gitignored).

# Site URL used for absolute og:image / twitter:image URLs (metadataBase).
# Defaults to https://mantlerobotics.com when unset.
# NEXT_PUBLIC_SITE_URL=https://mantlerobotics.com
